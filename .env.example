# ──────────────────────────────────────────────
# SwiftRide — Environment Variables
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=swiftride
POSTGRES_PASSWORD=swiftride_secret
POSTGRES_DB=swiftride
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=swiftride-group

# User Service
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8001
USER_SERVICE_SECRET_KEY=change-me-user-secret-key
USER_SERVICE_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Driver Service
DRIVER_SERVICE_HOST=0.0.0.0
DRIVER_SERVICE_PORT=8002

# Matching Service
MATCHING_SERVICE_HOST=0.0.0.0
MATCHING_SERVICE_PORT=8003
MATCHING_RADIUS_KM=5.0

# Ride Service
RIDE_SERVICE_HOST=0.0.0.0
RIDE_SERVICE_PORT=8004

# Pricing Service
PRICING_SERVICE_HOST=0.0.0.0
PRICING_SERVICE_PORT=8005
PRICING_BASE_FARE=2.50
PRICING_PER_KM_RATE=1.25
PRICING_PER_MIN_RATE=0.35
PRICING_SURGE_MULTIPLIER=1.0
